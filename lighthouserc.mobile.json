{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/main/docs/configuration.md",
  "ci": {
    "collect": {
      "staticDistDir": "./.vercel/output/static",
      "url": [
        "http://localhost/?theme=light",
        "http://localhost/?theme=dark",
        "http://localhost/about/?theme=light",
        "http://localhost/about/?theme=dark",
        "http://localhost/projects/?theme=light",
        "http://localhost/projects/?theme=dark",
        "http://localhost/projects/crucible/?theme=light",
        "http://localhost/projects/crucible/?theme=dark"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci-mobile"
    }
  }
}
