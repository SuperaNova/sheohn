---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import TableOfContents from '../../components/ui/TableOfContents.svelte';
import Lightbox from '../../components/ui/Lightbox.svelte';
import { Image } from 'astro:assets';

// Required for SSG — tells Astro which dynamic pages to prerender
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
  }));
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const entry = await getEntry('projects', id);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Case Study`}
  description={entry.data.summary}
  image={entry.data.image}
>
  <main class="min-h-screen bg-[var(--color-surface)] pt-20 pb-24 md:pt-32">
    <div
      class="relative mx-auto flex w-full max-w-[110rem] justify-center px-6 lg:px-12"
    >
      <aside
        class="sticky top-32 mr-8 hidden w-64 shrink-0 self-start xl:block 2xl:mr-16"
      >
        <TableOfContents client:visible headings={headings} />
      </aside>

      <article class="w-full max-w-[54rem] min-w-0 pb-32">
        <header class="mb-12">
          <div class="mb-6 flex flex-wrap items-center gap-3">
            <span
              class="text-xs font-bold tracking-[0.2em] text-[var(--color-on-surface-muted)] uppercase"
            >
              {entry.data.category} • {entry.data.status}
            </span>
          </div>

          <h1
            class="font-display text-4xl tracking-tight text-[var(--color-on-surface)] sm:text-5xl lg:text-6xl"
          >
            {entry.data.title}
          </h1>
        </header>

        {
          entry.data.image && (
            <div class="mb-16 aspect-video w-full overflow-hidden bg-[var(--color-surface-container)] md:aspect-[21/9]">
              <Image
                src={entry.data.image}
                alt={entry.data.title}
                width={1200}
                height={514}
                class="h-full w-full object-cover"
              />
            </div>
          )
        }

        <div
          class="mb-24 flex flex-col flex-wrap gap-x-16 gap-y-10 border-y border-[var(--color-outline-variant)] py-8 md:flex-row"
        >
          {
            [
              { label: 'Role', value: entry.data.role },
              { label: 'Timeline', value: entry.data.timeline },
              { label: 'Team', value: entry.data.team },
            ]
              .filter((field) => field.value)
              .map((field) => (
                <div class="flex flex-col gap-2">
                  <span class="text-xs font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">
                    {field.label}
                  </span>
                  <span class="text-sm font-medium text-[var(--color-on-surface)]">
                    {field.value}
                  </span>
                </div>
              ))
          }
          {
            entry.data.stack && entry.data.stack.length > 0 && (
              <div class="flex w-full flex-col gap-3 md:ml-auto md:w-auto">
                <span class="text-xs font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">
                  Core Stack
                </span>
                <div class="flex flex-wrap gap-2">
                  {entry.data.stack.map((skill) => (
                    <span class="rounded-full border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium tracking-wide text-[var(--color-on-surface-muted)]">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <div
          class="prose dark:prose-invert prose-lg prose-headings:font-display prose-headings:text-[var(--color-on-surface)] prose-headings:font-normal prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-6 prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4 md:prose-h2:text-3xl md:prose-h2:mt-16 md:prose-h3:text-2xl md:prose-h3:mt-12 prose-p:text-[var(--color-on-surface-muted)] prose-p:leading-relaxed prose-p:text-base md:prose-p:text-[17px] prose-a:text-[var(--color-tertiary)] hover:prose-a:text-[var(--color-on-surface)] prose-a:transition-colors prose-a:font-medium prose-strong:text-[var(--color-on-surface)] prose-strong:font-semibold prose-ul:text-[var(--color-on-surface-muted)] prose-ul:text-base md:prose-ul:text-[17px] prose-ol:text-[var(--color-on-surface-muted)] prose-ol:text-base md:prose-ol:text-[17px] prose-li:my-1 prose-code:text-[var(--color-tertiary)] prose-code:bg-[var(--color-surface-container)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:hidden prose-code:after:hidden prose-pre:bg-[var(--color-surface-container)] prose-pre:border prose-pre:border-[var(--color-outline-variant)] prose-pre:overflow-x-auto prose-img:w-full prose-img:h-auto prose-img:border prose-img:border-[var(--color-outline-variant)] max-w-none"
        >
          <Content />
        </div>
      </article>

      <div class="ml-8 hidden w-64 shrink-0 xl:block 2xl:ml-16"></div>
    </div>
  </main>

  {
    /* Click-to-zoom overlay for every image in the article (hero + diagrams). */
  }
  <Lightbox client:idle />
</BaseLayout>
