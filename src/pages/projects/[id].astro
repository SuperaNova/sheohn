---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import TableOfContents from '../../components/TableOfContents';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const entry = await getEntry('projects', id);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(entry);
---

<BaseLayout 
  title={`${entry.data.title} | Case Study`} 
  description={entry.data.summary}
  image={entry.data.image}
>
  <main class="min-h-screen bg-[var(--color-surface)] pt-32 pb-24">
    <div class="mx-auto w-full max-w-[110rem] px-6 lg:px-12 relative flex justify-center">
      
      {/* Left Sidebar: Table of Contents */}
      <aside class="hidden xl:block w-64 shrink-0 sticky top-32 self-start mr-8 2xl:mr-16">
        <TableOfContents client:load headings={headings} />
      </aside>

      {/* Center Main Content */}
      <article class="w-full max-w-[54rem] min-w-0 pb-32">
        
        {/* Header */}
        <header class="mb-12">
          <div class="mb-6 flex flex-wrap items-center gap-3">
            <span class="text-[10px] font-bold tracking-[0.2em] text-[var(--color-on-surface-muted)] uppercase">
              {entry.data.category} • {entry.data.status}
            </span>
          </div>
          
          <h1 class="font-display text-4xl text-[var(--color-on-surface)] sm:text-5xl lg:text-6xl tracking-tight">
            {entry.data.title}
          </h1>
        </header>

        {/* Hero Image */}
        {entry.data.image && (
          <div class="mb-16 aspect-video md:aspect-[21/9] w-full overflow-hidden bg-[var(--color-surface-container)]">
            <img 
              src={entry.data.image} 
              alt={entry.data.title} 
              class="h-full w-full object-cover"
            />
          </div>
        )}

        {/* Metadata section redesign */}
        <div class="flex flex-col md:flex-row flex-wrap gap-x-16 gap-y-10 mb-24 py-8 border-y border-[var(--color-outline-variant)]">
          {entry.data.role && (
            <div class="flex flex-col gap-2">
              <span class="text-[10px] font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">Role</span>
              <span class="text-sm font-medium text-[var(--color-on-surface)]">{entry.data.role}</span>
            </div>
          )}
          {entry.data.timeline && (
            <div class="flex flex-col gap-2">
              <span class="text-[10px] font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">Timeline</span>
              <span class="text-sm font-medium text-[var(--color-on-surface)]">{entry.data.timeline}</span>
            </div>
          )}
          {entry.data.team && (
            <div class="flex flex-col gap-2">
              <span class="text-[10px] font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">Team</span>
              <span class="text-sm font-medium text-[var(--color-on-surface)]">{entry.data.team}</span>
            </div>
          )}
          {entry.data.stack && entry.data.stack.length > 0 && (
            <div class="flex flex-col gap-3 w-full md:w-auto md:ml-auto">
              <span class="text-[10px] font-bold tracking-[0.2em] text-[var(--color-tertiary)] uppercase">Core Stack</span>
              <div class="flex flex-wrap gap-2">
                {entry.data.stack.map(skill => (
                  <span class="px-3 py-1.5 text-[11px] font-medium tracking-wide bg-[var(--color-surface-container)] border border-[var(--color-outline-variant)] rounded-full text-[var(--color-on-surface-muted)]">{skill}</span>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Markdown Content */}
        <div class="prose dark:prose-invert prose-lg max-w-none
          prose-headings:font-display prose-headings:text-[var(--color-on-surface)] prose-headings:font-normal prose-headings:tracking-tight
          prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-6
          prose-h3:text-2xl prose-h3:mt-12 prose-h3:mb-4
          prose-p:text-[var(--color-on-surface-muted)] prose-p:leading-relaxed prose-p:text-[16px]
          prose-a:text-[var(--color-tertiary)] hover:prose-a:text-[var(--color-on-surface)] prose-a:transition-colors prose-a:font-medium
          prose-strong:text-[var(--color-on-surface)] prose-strong:font-semibold
          prose-ul:text-[var(--color-on-surface-muted)] prose-ul:text-[16px]
          prose-ol:text-[var(--color-on-surface-muted)] prose-ol:text-[16px]
          prose-li:my-1
          prose-code:text-[var(--color-tertiary)] prose-code:bg-[var(--color-surface-container)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:hidden prose-code:after:hidden
          prose-pre:bg-[var(--color-surface-container)] prose-pre:border prose-pre:border-[var(--color-outline-variant)]
          prose-img:w-full prose-img:border prose-img:border-[var(--color-outline-variant)]">
          <Content />
        </div>

      </article>

      {/* Right Spacer for Perfect Centering */}
      <div class="hidden xl:block w-64 shrink-0 ml-8 2xl:ml-16"></div>

    </div>
  </main>
</BaseLayout>
