---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection';
import FeaturedProjects from '../components/FeaturedProjects';
import ScrollProgress from '../components/ScrollProgress';
import Loader from '../components/Loader';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 1)
  .map((p) => ({ slug: p.id, ...p.data }));
---

<BaseLayout
  title="Jared Sheohn L. Acebes - Portfolio"
  description="Portfolio of Jared Sheohn L. Acebes - Software Developer & Systems Architect"
>
  <Loader client:load />
  <ScrollProgress client:load />

  <main class="bg-[var(--color-surface)] pt-16">
    <!-- React Island: animated hero -->
    <HeroSection client:load />

    <!-- React Island: projects rendered through array/object mapping -->
    <div class="relative z-10 bg-transparent">
      <FeaturedProjects client:visible projects={featuredProjects} />
    </div>
  </main>
</BaseLayout>
