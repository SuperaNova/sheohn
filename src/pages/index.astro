---
import '../styles/global.css';
import HeroSection from '../components/HeroSection';
import FeaturedProjects from '../components/FeaturedProjects';
import SectionReveal from '../components/SectionReveal';
import ScrollProgress from '../components/ScrollProgress';
import HeaderNav from '../components/HeaderNav';
import ExperienceTimeline from '../components/ExperienceTimeline';
import Loader from '../components/Loader';
import CustomCursor from '../components/CustomCursor';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Portfolio of Jared Sheohn L. Acebes - Software Developer & Systems Architect."
    />
    <title>Jared Sheohn L. Acebes | sheohn.dev</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body
    class="selection:bg-[color-mix(in_srgb,var(--color-primary)_42%,transparent)] selection:text-slate-100 relative"
  >
    <div class="site-noise pointer-events-none fixed inset-0 z-50 opacity-20 dark:opacity-30 mix-blend-overlay"></div>
    <div class="site-grid pointer-events-none fixed inset-0 z-0 opacity-10"></div>
    
    <CustomCursor client:load transition:persist />
    <Loader client:load />
    <ScrollProgress client:load />
    <HeaderNav client:load />

    <main class="bg-[var(--color-surface)] pt-16">
      <!-- React Island: animated hero -->
      <HeroSection client:load />

      <!-- React Island: projects rendered through array/object mapping -->
      <div class="bg-transparent relative z-10">
        <FeaturedProjects client:visible />
      </div>

    </main>

    <!-- TODO: add my footer -->
    <footer
      id="footer"
      class="scroll-mt-24 bg-[color-mix(in_srgb,var(--color-surface)_90%,transparent)] border-t-2 border-[var(--color-on-surface-muted)] py-16 relative z-10"
    >
      <div
        class="mx-auto grid w-full max-w-[90rem] gap-12 px-6 md:grid-cols-[1.2fr_0.8fr_0.9fr] md:px-10"
      >
        <div>
          <p class="font-display text-3xl text-[var(--color-on-surface)]">
            Jared Sheohn L. Acebes
          </p>
          <p
            class="mt-3 max-w-md text-sm leading-relaxed text-[var(--color-on-surface-muted)]"
          >
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur
            blandit tempus porttitor.
          </p>
        </div>

        <div>
          <p
            class="text-xs tracking-[0.16em] text-[var(--color-primary-container)] uppercase"
          >
            Navigation
          </p>
          <nav
            class="mt-4 grid gap-2 text-sm text-[var(--color-on-surface-muted)]"
          >
            <a
              href="/"
              class="transition hover:text-[var(--color-on-surface)]">Home</a
            >
            <a
              href="/#projects"
              class="transition hover:text-[var(--color-on-surface)]"
              >Projects</a
            >
            <a
              href="/about#stack"
              class="transition hover:text-[var(--color-on-surface)]">Stack</a
            >
            <a
              href="/about"
              class="transition hover:text-[var(--color-on-surface)]">About</a
            >
          </nav>
        </div>

        <div>
          <p
            class="text-xs tracking-[0.16em] text-[var(--color-primary-container)] uppercase"
          >
            Connect
          </p>
          <nav
            class="mt-4 grid gap-2 text-sm text-[var(--color-on-surface-muted)]"
          >
            <a
              href="https://github.com/"
              target="_blank"
              rel="noreferrer"
              class="transition hover:text-[var(--color-on-surface)]">GitHub</a
            >
            <a
              href="https://linkedin.com/"
              target="_blank"
              rel="noreferrer"
              class="transition hover:text-[var(--color-on-surface)]"
              >LinkedIn</a
            >
            <a
              href="mailto:you@sheohn.dev"
              class="transition hover:text-[var(--color-on-surface)]">Email</a
            >
            <!-- TODO: add my resume pdf -->
            <a
              href="/resume.pdf"
              class="font-medium text-[var(--color-primary-container)] transition hover:text-[var(--color-on-surface)]"
              >Download Resume</a
            >
          </nav>
        </div>
      </div>

      <div
        class="mx-auto mt-12 w-full max-w-[90rem] border-t border-white/10 px-6 pt-6 text-xs text-[var(--color-on-surface-muted)] md:px-10"
      >
        &copy; {new Date().getFullYear()} sheohn.dev
      </div>
    </footer>
  </body>
</html>
