---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionReveal from '../components/SectionReveal.svelte';
import ScrollProgress from '../components/ScrollProgress.svelte';
import ExperienceTimeline from '../components/ExperienceTimeline.svelte';
---

<BaseLayout
  title="About | sheohn.dev"
  description="About Jared Sheohn L. Acebes and his technical experience."
>
  <ScrollProgress client:idle />

  <main class="min-h-screen bg-[var(--color-surface)] pt-32">
    <SectionReveal
      client:visible
      id="about"
      class="content-wrap relative z-10 flex scroll-mt-24 flex-col bg-transparent pb-24"
    >
      <div class="grid items-start gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div>
          <h2
            class="font-display text-4xl text-[var(--color-on-surface)] sm:text-5xl"
          >
            About Me
          </h2>
          <p
            class="mt-6 max-w-2xl text-lg leading-[1.6] text-[var(--color-on-surface)]"
          >
            I am a Software Developer and Systems Architect focused on building
            scalable, resilient, and highly interactive applications. I
            specialize in the intersection of modern frontend architectures and
            robust backend systems.
          </p>
          <p
            class="mt-4 max-w-2xl leading-[1.6] text-[var(--color-on-surface-muted)]"
          >
            With a background in both systems engineering and frontend
            development, I enjoy bridging the gap between deep technical
            architecture and seamless user experiences. When I'm not coding, I'm
            usually exploring new open-source tools or writing technical
            documentation.
          </p>
        </div>

        <div
          class="h-fit rounded-2xl border border-[var(--color-outline-variant)] bg-[color-mix(in_srgb,var(--color-surface-container-high)_80%,transparent)] p-8 shadow-sm"
        >
          <p
            class="text-xs font-semibold tracking-[0.14em] text-[var(--color-tertiary)] uppercase"
          >
            Current Focus
          </p>
          <h3
            class="font-display mt-3 text-2xl font-semibold text-[var(--color-on-surface)]"
          >
            Building AI-integrated Web Systems
          </h3>
          <p
            class="mt-4 text-sm leading-relaxed text-[var(--color-on-surface-muted)]"
          >
            Exploring the boundaries of LLMs in production environments and
            building tools that enhance developer productivity. Currently
            focused on RAG architectures and edge computing.
          </p>
        </div>
      </div>

      <ExperienceTimeline client:visible />
    </SectionReveal>

    <SectionReveal
      client:visible
      id="stack"
      class="content-wrap relative z-10 flex scroll-mt-24 flex-col border-t border-[var(--color-outline-variant)] bg-transparent py-24"
    >
      <div class="mb-16 flex items-end justify-between gap-6">
        <h2
          class="font-display text-4xl text-[var(--color-on-surface)] sm:text-5xl"
        >
          Tech Stack
        </h2>
        <span
          class="text-xs font-medium tracking-[0.2em] text-[var(--color-on-surface-muted)] uppercase"
          >Technology Overview</span
        >
      </div>

      <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
        <article>
          <h3
            class="mb-6 text-xs font-semibold tracking-[0.2em] text-[var(--color-tertiary)] uppercase"
          >
            Core
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              ['TypeScript', 'JavaScript', 'React', 'Node.js', 'Python'].map(
                (item) => (
                  <span class="rounded-md border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium text-[var(--color-on-surface-muted)]">
                    {item}
                  </span>
                ),
              )
            }
          </div>
        </article>

        <article>
          <h3
            class="mb-6 text-xs font-semibold tracking-[0.2em] text-[var(--color-tertiary)] uppercase"
          >
            Frontend
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              [
                'Next.js',
                'Astro',
                'Tailwind CSS',
                'Framer Motion',
                'Zustand',
              ].map((item) => (
                <span class="rounded-md border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium text-[var(--color-on-surface-muted)]">
                  {item}
                </span>
              ))
            }
          </div>
        </article>

        <article>
          <h3
            class="mb-6 text-xs font-semibold tracking-[0.2em] text-[var(--color-tertiary)] uppercase"
          >
            Backend & DB
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              ['PostgreSQL', 'MongoDB', 'Express', 'REST API', 'GraphQL'].map(
                (item) => (
                  <span class="rounded-md border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium text-[var(--color-on-surface-muted)]">
                    {item}
                  </span>
                ),
              )
            }
          </div>
        </article>

        <article>
          <h3
            class="mb-6 text-xs font-semibold tracking-[0.2em] text-[var(--color-tertiary)] uppercase"
          >
            Infra & Tools
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              ['Docker', 'AWS', 'GitHub Actions', 'Git', 'Figma', 'Linux'].map(
                (item) => (
                  <span class="rounded-md border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium text-[var(--color-on-surface-muted)]">
                    {item}
                  </span>
                ),
              )
            }
          </div>
        </article>
      </div>
    </SectionReveal>
  </main>
</BaseLayout>
