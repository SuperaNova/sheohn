---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionReveal from '../components/ui/SectionReveal.svelte';
import ExperienceTimeline from '../components/sections/ExperienceTimeline.svelte';
import { personalInfo } from '../data/personalInfo';
---

<BaseLayout
  title="About Me"
  description={`About ${personalInfo.name} and his technical experience.`}
>
  <main class="min-h-screen bg-[var(--color-surface)] pt-32">
    <SectionReveal
      client:visible
      id="about"
      class="content-wrap relative z-10 flex scroll-mt-24 flex-col bg-transparent pb-24"
    >
      <div class="grid items-start gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div>
          <h2
            class="font-display text-4xl text-[var(--color-on-surface)] sm:text-5xl"
          >
            About Me
          </h2>
          {
            personalInfo.about.paragraphs.map((p, i) => (
              <p
                class={`max-w-2xl text-[var(--color-on-surface${i === 0 ? '' : '-muted'})] leading-[1.6] ${i === 0 ? 'mt-6 text-lg' : 'mt-4'}`}
              >
                {p}
              </p>
            ))
          }
        </div>

        <div
          class="h-fit rounded-2xl border border-[var(--color-outline-variant)] bg-[color-mix(in_srgb,var(--color-surface-container-high)_80%,transparent)] p-8 shadow-sm"
        >
          <p class="readout">Current Focus</p>
          <h3
            class="font-display mt-3 text-2xl font-semibold text-[var(--color-on-surface)]"
          >
            {personalInfo.about.currentFocusTitle}
          </h3>
          <p
            class="mt-4 text-sm leading-relaxed text-[var(--color-on-surface-muted)]"
          >
            {personalInfo.about.currentFocusDescription}
          </p>
        </div>
      </div>

      <ExperienceTimeline client:visible />
    </SectionReveal>

    <SectionReveal
      client:visible
      id="stack"
      class="content-wrap relative z-10 flex scroll-mt-24 flex-col border-t border-[var(--color-outline-variant)] bg-transparent py-24"
    >
      <div class="mb-16 flex items-end justify-between gap-6">
        <h2
          class="font-display text-4xl text-[var(--color-on-surface)] sm:text-5xl"
        >
          Tech Stack
        </h2>
        <span class="readout">Technology Overview</span>
      </div>

      <div class="grid gap-12 lg:grid-cols-3">
        {
          personalInfo.techStack.map((group) => (
            <article>
              <h3 class="readout mb-6">{group.category}</h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="rounded-md border border-[var(--color-outline-variant)] bg-[var(--color-surface-container)] px-3 py-1.5 text-xs font-medium text-[var(--color-on-surface-muted)]">
                    {item}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </SectionReveal>
  </main>
</BaseLayout>
