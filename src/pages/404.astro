---
import BaseLayout from '../layouts/BaseLayout.astro';
import PongGame from '../components/PongGame.svelte';
---

<BaseLayout
  title="404 | Page Not Found"
  description="The page you are looking for does not exist."
>
  <main
    class="flex min-h-screen flex-col items-center justify-center bg-[var(--color-surface)] px-6 py-20"
  >
    <div class="w-full max-w-2xl text-center">
      <h1
        class="font-display text-7xl font-bold text-[var(--color-primary-container)] opacity-50 md:text-9xl"
      >
        404
      </h1>
      <h2
        class="mt-4 text-xl font-semibold tracking-wide text-[var(--color-on-surface)] md:text-2xl"
      >
        SYSTEM_ERR: ENDPOINT_NOT_FOUND
      </h2>
      <p class="mx-auto mt-4 max-w-md text-[var(--color-on-surface-muted)]">
        The requested resource could not be located. You can play a game against
        the SYS.AI while you wait, or return to the main node.
      </p>

      <PongGame client:visible />

      <div class="mt-10">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-lg bg-[var(--color-surface-container-high)] px-6 py-3 text-sm font-semibold tracking-[0.1em] text-[var(--color-on-surface)] transition hover:bg-[var(--color-surface-container-highest)]"
        >
          RETURN HOME
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
