---
import '../styles/global.css';
import HeaderNav from '../components/chrome/HeaderNav.svelte';
import NavProgress from '../components/chrome/NavProgress.svelte';
// @ts-expect-error - svelte2tsx false positive on Svelte 5 component with no props
import CustomCursor from '../components/chrome/CustomCursor.svelte';
import ScenePilot from '../components/agent/ScenePilot.svelte';
import CommandDeck from '../components/agent/CommandDeck.svelte';
import { ClientRouter } from 'astro:transitions';

import { personalInfo } from '../data/personalInfo';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = `Portfolio of ${personalInfo.name} - ${personalInfo.title}.`,
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || 'https://sheohn.dev',
);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: personalInfo.name,
        url: 'https://sheohn.dev',
        jobTitle: personalInfo.title,
        sameAs: [personalInfo.socials.github, personalInfo.socials.linkedin],
      })}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: `${personalInfo.name} Portfolio`,
        url: 'https://sheohn.dev',
      })}
    />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />

    <script is:inline>
      function applyThemeAndLoader() {
        const isLocalAudit =
          window.location.hostname === 'localhost' ||
          window.location.hostname === '127.0.0.1';
        const urlTheme = isLocalAudit
          ? new URLSearchParams(window.location.search).get('theme')
          : null;
        const override =
          urlTheme === 'light' || urlTheme === 'dark' ? urlTheme : null;
        // Default to light on first visit to showcase the canonical design.
        // Returning users keep their explicit choice (localStorage); OS preference
        // is intentionally ignored so the design lands the same way every time.
        const theme = override || localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // 2. Prevent Loader from playing multiple times per session
        if (sessionStorage.getItem('loader-played')) {
          document.documentElement.classList.add('skip-loader');
        } else {
          sessionStorage.setItem('loader-played', 'true');
        }
      }

      // Run on initial load
      applyThemeAndLoader();

      // Run on every page navigation (Astro View Transitions)
      document.addEventListener('astro:after-swap', applyThemeAndLoader);
    </script>
  </head>

  <body
    class="relative selection:bg-[color-mix(in_srgb,var(--color-primary)_42%,transparent)] selection:text-slate-100"
  >
    <div
      class="site-noise pointer-events-none fixed inset-0 z-50 opacity-20 mix-blend-overlay dark:opacity-30"
    >
    </div>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[1000] focus:rounded-md focus:bg-[var(--color-tertiary)] focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg"
    >
      Skip to main content
    </a>

    <NavProgress client:idle transition:persist />
    <CustomCursor client:idle transition:persist />
    <ScenePilot client:idle transition:persist />
    <HeaderNav client:load />

    <div id="main-content">
      <slot />
    </div>

    <!-- Unified command surface: deterministic /commands + the AI agent in one
         docked bar. transition:persist keeps the conversation alive while the
         agent navigates the site (scene control / opening case studies). -->
    <CommandDeck client:idle transition:persist />
  </body>
</html>
