{
  "name": "sheohn",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "astro check",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.svelte-check.json",
    "knip": "knip",
    "secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "lighthouse": "lhci autorun && node scripts/lh-summary.mjs",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.json && node scripts/lh-summary.mjs --dir .lighthouseci-mobile",
    "lighthouse:local": "npm run build && lhci autorun && node scripts/lh-summary.mjs",
    "lighthouse:live": "lhci autorun --config=lighthouserc.live.json && node scripts/lh-summary.mjs --dir .lighthouseci-live",
    "preflight": "npm run format:check && npm run lint && npm run check && npm run check:svelte && npm run knip && npm run secretlint && npm run test:unit:coverage && npm run build && npm run lighthouse && npm run lighthouse:mobile && npm run test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,svelte,astro,mjs,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,mdx,json,jsonc,yaml,yml,css,html}": [
      "prettier --write"
    ],
    "*": [
      "secretlint --secretlintignore .gitignore"
    ]
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.59",
    "@ai-sdk/svelte": "^4.0.191",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.149",
    "astro": "^6.1.3",
    "dotenv": "^17.4.1",
    "resend": "^6.12.4",
    "svelte": "^5.55.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^8.1.1",
    "@astrojs/vercel": "^10.0.4",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.0.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "secretlint": "^13.0.2",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.7"
  }
}
