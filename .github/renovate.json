{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "labels": ["dependencies"],
  "minimumReleaseAge": "7 days",
  "versioning": "npm",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 2,
  "prHourlyLimit": 0,
  "rebaseWhen": "conflicted",

  "packageRules": [
    {
      "description": "Block pre-release versions (alpha/beta/rc/canary/next) for stable >=1.0 packages",
      "matchCurrentVersion": "!/^0\\./",
      "allowedVersions": "!/^[0-9]+\\.[0-9]+\\.[0-9]+-.*/"
    },

    {
      "description": "Only allow Node.js LTS (even-numbered) major versions",
      "matchPackageNames": ["node"],
      "allowedVersions": "/^(18|20|22|24|26)\\./"
    },

    {
      "description": "Group ALL non-major updates into one PR and auto-merge",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major",
      "automerge": true,
      "automergeType": "pr"
    },

    {
      "description": "Group ALL major updates into one PR — manual review required",
      "matchUpdateTypes": ["major"],
      "groupName": "all major dependencies",
      "groupSlug": "all-major",
      "automerge": false,
      "labels": ["dependencies", "major-update"]
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "minimumReleaseAge": "0 days",
    "labels": ["dependencies", "security"]
  },

  "enabled": true
}
