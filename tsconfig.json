{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": [
    "dist",
    ".vercel",
    "coverage",
    "playwright-report",
    "test-results",
    ".lighthouseci",
    ".lighthouseci-mobile",
    "node_modules"
  ]
}
